  "normalization_eps": 1e-6,
  "device": "cuda",
  "num_workers": 4,
  "pin_memory": true,
  "seed": 2026,
  "save_interval": 10,
  "log_interval": 10,
  "output_dir": "outputs/gnss_transformer",
  "use_position_encoding": true
}
